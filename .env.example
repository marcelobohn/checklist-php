# Credenciais do banco usadas pelo docker-compose.yml e por conexaoBD.php.
# Copie para `.env` e ajuste para o seu ambiente. Os valores abaixo são os
# defaults de desenvolvimento (o stack sobe sem precisar de .env).
#
# A senha tem fonte única: o mesmo DB_PASSWORD é aplicado ao MySQL (root) e
# ao container web. NÃO versione o seu `.env` com segredos reais.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=checklist
DB_USER=root
DB_PASSWORD=123
